# Copy this file to .env.local and fill in your actual values
# cp .env.local.example .env.local

# YouTube API (get from https://console.cloud.google.com/)
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_CHANNEL_ID=your_youtube_channel_id_here
NEXT_PUBLIC_YOUTUBE_CHANNEL_ID=your_youtube_channel_id_here

# Supabase (get from https://app.supabase.com/ project settings)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# NextAuth / Google OAuth (get from https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
NEXTAUTH_URL=http://localhost:3000  # Required for production, optional for local dev
NEXTAUTH_SECRET=your_nextauth_secret_here  # Generate: openssl rand -base64 32

# OpenAI (for AI chat - get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_VIDEO_VECTOR_STORE_ID=your_vector_store_id_here  # Optional

# Gemini (for image generation - get from https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Vercel Blob (auto-provided on Vercel, or run: vercel link && vercel env pull)
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here

# Resend (email delivery for daily admin brief)
RESEND_API_KEY=your_resend_api_key_here
ADMIN_BRIEF_FROM_EMAIL=onboarding@resend.dev  # Optional override
