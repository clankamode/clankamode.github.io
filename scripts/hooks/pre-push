#!/bin/sh
# Pre-push hook: runs lint, typecheck, tests, and agent checks before pushing.
# Installed via scripts/install-hooks.sh — committed so the whole team gets it.

set -e

echo "🔍 Running pre-push checks..."

echo "  → lint"
npm run lint --silent

echo "  → typecheck"
npm run typecheck --silent

echo "  → tests"
npm run test --silent

echo "  → agent checks"
npm run check:agent --silent

echo "✅ Pre-push checks passed."
